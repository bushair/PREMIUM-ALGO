//@version=6
indicator("FVG Radar+ Alerts", overlay=true)

// === INPUTS ===
i_up = input.float(5, "Radar Upper Band (%)", group = "Visibility")
i_down = input.float(10, "Radar Lower Band (%) ", group = "Visibility")
i_per = input.float(0.05, "Minimum FVG Size (%)", group = "Visibility")
half = input.bool(true, "Clear FVG When Price Reaches Half", group = "Visibility")
i_alarm = input.int(5, "Wait X Bars After FVG Formation", group="Alert Trigger")

tsize = input.int(10, "Text Size", group="Style")
bullColor = input.color(color.green, "Bullish FVG Color", group="Style")
bearColor = input.color(color.red, "Bearish FVG Color", group="Style")
radarColor = input.color(color.yellow, "Radar Color", group="Style")
opacity = input.int(70, "Opacity", minval=0, maxval=100, group="Style")
radar = input.bool(true, "Radar Show/Hide", group="Style")

// === TYPES ===
type bullFVG
    float bullHigh
    float bullLow
    int bullTime
    int bullBar = bar_index

type bearFVG
    float bearHigh
    float bearLow
    int bearTime
    int bearBar = bar_index

// === ARRAYS ===
var bullFvg = array.new<bullFVG>()
var bearFvg = array.new<bearFVG>()

// === DETECT FVG ===
detectFVG() =>
    isBullishFVG = close[1] > high[2] and low > high[2]
    isBearishFVG = close[1] < low[2] and high < low[2]

    newBullFvg = bullFVG.new(low, high[2], time[1])
    newBearFvg = bearFVG.new(high, low[2], time[1])

    bullper = ((low - high[2]) / high[2]) * 100
    bearper = ((low[2] - high) / high) * 100

    if isBullishFVG and bullper > i_per
        bullFvg.push(newBullFvg)

    if isBearishFVG and bearper > i_per
        bearFvg.push(newBearFvg)

    if bullFvg.size() > 100
        array.shift(bullFvg)

    if bearFvg.size() > 100
        array.shift(bearFvg)

    [isBullishFVG, isBearishFVG]

// === MAIN ===
[bullTrigger, bearTrigger] = detectFVG()

// ✅ NEW ALERT CONDITIONS (FVG FORMATION)
alertcondition(bullTrigger, title="Bullish FVG Formed", message="Bullish FVG detected")

alertcondition(bearTrigger, title="Bearish FVG Formed", message="Bearish FVG detected")

// === COLORS ===
bullFVGColor = color.new(bullColor, opacity)
bearFVGColor = color.new(bearColor, opacity)

// === CLEAR OLD BOXES ===
a_allBoxes = box.all
if array.size(a_allBoxes) > 0
    for i = 0 to array.size(a_allBoxes) - 1
        box.delete(array.get(a_allBoxes, i))

// === DRAW BULL FVG ===
if barstate.islast and bullFvg.size() > 0
    for i = 0 to bullFvg.size() - 1
        bullList = bullFvg.get(i)
        yuzde = ((close - bullList.bullHigh) / close) * 100

        if yuzde < i_down
            per = ((bullList.bullHigh - bullList.bullLow) / bullList.bullLow) * 100

            box.new(
                 left=bullList.bullTime,
                 top=bullList.bullHigh,
                 right=time_close,
                 bottom=bullList.bullLow,
                 border_color=color.new(bullColor, 70),
                 text=str.tostring(per, format.percent),
                 text_size=tsize,
                 text_halign=text.align_right,
                 text_color=color.green,
                 bgcolor=bullFVGColor,
                 xloc=xloc.bar_time)

// === DRAW BEAR FVG ===
if barstate.islast and bearFvg.size() > 0
    for i = 0 to bearFvg.size() - 1
        bearList = bearFvg.get(i)
        yuzde = ((bearList.bearLow - close) / bearList.bearLow) * 100

        if yuzde < i_up
            per = ((bearList.bearLow - bearList.bearHigh) / bearList.bearHigh) * 100

            box.new(
                 left=bearList.bearTime,
                 top=bearList.bearHigh,
                 right=time_close,
                 bottom=bearList.bearLow,
                 border_color=color.new(bearColor, 70),
                 text=str.tostring(per, format.percent),
                 text_size=tsize,
                 text_halign=text.align_right,
                 text_color=color.red,
                 bgcolor=bearFVGColor,
                 xloc=xloc.bar_time)

// === CLEANUP LOGIC ===
if bullFvg.size() > 0
    for i = bullFvg.size() - 1 to 0
        bullItem = bullFvg.get(i)
        middlePoint = (bullItem.bullHigh + bullItem.bullLow) / 2

        if half
            if ta.crossunder(low, middlePoint)
                bullFvg.remove(i)
        else
            if ta.crossunder(low, bullItem.bullLow)
                bullFvg.remove(i)

if bearFvg.size() > 0
    for i = bearFvg.size() - 1 to 0
        bearItem = bearFvg.get(i)
        middlePoint = (bearItem.bearHigh + bearItem.bearLow) / 2

        if half
            if ta.crossover(high, middlePoint)
                bearFvg.remove(i)
        else
            if ta.crossover(high, bearItem.bearLow)
                bearFvg.remove(i)

// === RADAR ===
lh = close * (1 + (i_up / 100))
ll = close * (1 - (i_down / 100))

if radar
    box.new(
         bar_index,
         lh,
         bar_index + 20,
         ll,
         border_color=color.new(radarColor, 60),
         extend=extend.left,
         bgcolor=color.new(radarColor, 100),
         border_style=line.style_dotted,
         text="Radar Area",
         text_size=tsize,
         text_halign=text.align_right,
         text_valign=text.align_top,
         text_color=radarColor)
